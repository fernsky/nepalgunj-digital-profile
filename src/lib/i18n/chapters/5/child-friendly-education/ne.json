{
  "sectionNumber": "५.१.७",
  "title": "बालमैत्री शिक्षा सम्बन्धी विवरण",
  "type": "multi-block",
  "blocks": [
    {
      "type": "paragraph",
      "content": "हाल नेपालगञ्ज उप-महानगरपालिकाले बालमैत्री शिक्षा सम्बन्धी गरेका प्रयासहरु निम्न बमोजिम रहेका छन् ।"
    },
    {
      "type": "list",
      "title": "प्रयासहरु:",
      "content": [
        "दण्डरहित शिक्षा",
        "बालविकासमा खेल सामाग्रीको व्यवस्था",
        "क्षमता विकास तालिमको व्यवस्था",
        "बालमैत्री खानेपानी तथा शौचालयको व्यवस्था",
        "बालक्लबहरुको गठन",
        "बाल शिक्षा सम्बन्धी कार्यक्रम सञ्चालन"
      ]
    }
  ]
}