---
import Layout from "../../layouts/Layout.astro";
import { type Lang } from "../../i18n/translations";
import { t, getAnnexes } from "../../i18n/utils";
import SectionRenderer from "../../components/SectionRenderer.astro";

export function getStaticPaths() {
  return [{ params: { lang: "ne" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const annexItems = getAnnexes();

// Load all JSON files statically at build time
const jsonFiles = import.meta.glob('../../lib/i18n/annexes/**/*.json', { eager: true }) as Record<string, { default: any }>;

function getAnnexContent(slug: string) {
  // Try exact file first (e.g. annexes/staff/en.json)
  const exactKey = `../../lib/i18n/annexes/${slug}/${lang}.json`;
  if (jsonFiles[exactKey]) {
    return jsonFiles[exactKey].default;
  }

  // Try folder pattern (e.g. annexes/staff/en/*.json)
  const folderPrefix = `../../lib/i18n/annexes/${slug}/${lang}/`;
  const folderEntries = Object.entries(jsonFiles).filter(([k]) => k.startsWith(folderPrefix));
  
  if (folderEntries.length > 0) {
    // Sort files to ensure stable order
    folderEntries.sort((a, b) => a[0].localeCompare(b[0], undefined, {numeric: true}));
    
    // Find index file for title/number (usually 00-index.json or just base metadata)
    const indexEntry = folderEntries.find(([k]) => k.includes('index.json')) || folderEntries[0];
    const indexPart = indexEntry[1].default;
    
    const combined = { ...indexPart, type: 'multi-block', blocks: [...(indexPart.blocks || [])] };
    
    for (const [k, v] of folderEntries) {
      if (k === indexEntry[0]) continue; // Skip index file
      
      const part = v.default;
      if (part.type === 'multi-block' && part.blocks) {
        combined.blocks.push(...part.blocks);
      } else {
        combined.blocks.push(part);
      }
    }
    return combined;
  }

  return null;
}
---

<Layout lang={lang} title={t(lang, "nav.annexes")}>
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0" style="background:linear-gradient(135deg, rgba(255,255,255,0.03) 0%, transparent 50%);"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);">
        <span class="text-sm font-medium" style="color:var(--text-heading);">{t(lang, "nav.annexes")}</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-4" style="color:var(--text-heading);">{t(lang, "nav.annexes")}</h1>
      <p class="text-lg" style="color:var(--text-body);">
        {lang === "ne" ? "उप-महानगरपालिकाको वस्तुस्थिति विवरणमा समावेश भएका अनुसूचीहरू" : "Annexes included in the Sub-Metropolitan City situational analysis"}
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 lg:px-14 pb-20">
    <div class="space-y-16">
      {annexItems.map((annex) => {
        const content = getAnnexContent(annex.slug);
        
        return (
          <div id={annex.slug} class="scroll-mt-24">
            <div class="mb-6 pb-2 border-b-2" style="border-color: rgba(192, 57, 43, 0.2);">
              <h2 class="text-2xl font-bold" style="color: #c0392b;">{annex.title[lang]}</h2>
            </div>
            {content ? (
              <SectionRenderer content={content} lang={lang} id={annex.slug} />
            ) : (
              <div class="rounded-lg p-8" style="background:var(--card-bg);border:1px solid var(--card-border);">
                <p class="italic text-center text-lg mt-4" style="color:var(--text-muted);">
                  {lang === "ne" ? "सामग्री चाँडै थपिनेछ..." : "Content coming soon..."}
                </p>
              </div>
            )}
          </div>
        );
      })}
    </div>

    <div class="flex justify-between items-center mt-16 pt-8" style={`border-top:1px solid var(--border);`}>
      <a href={`/${lang}/chapter-8`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-medium no-underline" style="color:var(--text-body);background:var(--card-bg);border:1px solid var(--card-border);">
        ← {t(lang, "chapter.label")} 8
      </a>
      <a href={`/${lang}/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-medium no-underline" style="color:var(--text-body);background:var(--card-bg);border:1px solid var(--card-border);">
        {t(lang, "nav.home")}
      </a>
    </div>
  </div>
</Layout>

<style>
  .annex-content {
    font-family: inherit;
  }
</style>
