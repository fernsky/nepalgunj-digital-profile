---
import Layout from "../../layouts/Layout.astro";
import { type Lang } from "../../i18n/translations";
import { t, getAnnexes } from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "ne" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const annexItems = getAnnexes();
---

<Layout lang={lang} title={t(lang, "nav.annexes")}>
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0" style="background:linear-gradient(135deg, rgba(29,78,216,0.06) 0%, transparent 50%);"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4" style="background:rgba(29,78,216,0.15);border:1px solid rgba(29,78,216,0.3);">
        <span class="text-primary-400 text-sm font-medium">{t(lang, "nav.annexes")}</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-4" style="color:var(--text-heading);">{t(lang, "nav.annexes")}</h1>
      <p class="text-lg" style="color:var(--text-body);">
        {lang === "ne" ? "उप-महानगरपालिकाको वस्तुस्थिति विवरणमा समावेश भएका अनुसूचीहरू" : "Annexes included in the Sub-Metropolitan City situational analysis"}
      </p>
    </div>
  </section>
  <div class="max-w-7xl mx-auto px-6 lg:px-14 pb-20">
    <div class="space-y-6">
      {annexItems.map((annex, i) => (
        <section id={annex.id} class="scroll-mt-24 rounded-xl p-6 transition-all duration-300" style={`background:var(--card-bg);border:1px solid var(--card-border);`}>
          <div class="flex items-start gap-4">
            <span class="text-3xl font-black font-mono" style="color:var(--text-muted);">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h2 class="text-xl font-bold mb-3" style="color:var(--text-heading);">{annex.title[lang]}</h2>
              <div class="w-16 h-0.5 bg-primary-500 rounded-full mb-4"></div>
              <p class="italic text-sm" style="color:var(--text-muted);">
                {lang === "ne" ? "सामग्री चाँडै थपिनेछ..." : "Content coming soon..."}
              </p>
            </div>
          </div>
        </section>
      ))}
    </div>
    <div class="flex justify-between items-center mt-16 pt-8" style={`border-top:1px solid var(--border);`}>
      <a href={`/${lang}/chapter-8`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium no-underline" style="color:var(--text-body);background:var(--card-bg);border:1px solid var(--card-border);">
        ← {t(lang, "chapter.label")} 8
      </a>
      <a href={`/${lang}/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium no-underline" style="color:var(--text-body);background:var(--card-bg);border:1px solid var(--card-border);">
        {t(lang, "nav.home")}
      </a>
    </div>
  </div>
</Layout>
