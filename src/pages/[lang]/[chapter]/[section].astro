---
import Layout from "../../../layouts/Layout.astro";
import { type Lang, chapters } from "../../../i18n/translations";
import { t, getAllSections, formatSectionId } from "../../../i18n/utils";
import SectionRenderer from "../../../components/SectionRenderer.astro";
import Chapter4Renderer from "../../../components/chapters/4/Chapter4Renderer.astro";


export async function getStaticPaths() {
  const allSections = getAllSections();
  const paths: any[] = [];
  for (const { chapterNum, chapterSlug, section } of allSections) {
    paths.push({ 
      params: { lang: "ne", chapter: chapterSlug, section: section.slug }, 
      props: { chapterNum, section } 
    });
    paths.push({ 
      params: { lang: "en", chapter: chapterSlug, section: section.slug }, 
      props: { chapterNum, section } 
    });
  }
  return paths;
}

const { lang, chapter: chapterSlug, section: sectionSlug } = Astro.params;
const { chapterNum, section } = Astro.props;
const currentLang = lang as Lang;

// Load all JSON files statically at build time
const jsonFiles = import.meta.glob('../../../lib/i18n/chapters/**/*.json', { eager: true }) as Record<string, { default: any }>;

// Try to get section content
const key = `../../../lib/i18n/chapters/${chapterNum}/${sectionSlug}/${lang}.json`;
const content = jsonFiles[key]?.default ?? null;
---

<Layout lang={currentLang} title={`${formatSectionId(section.id)} ${section.title[currentLang]}`}>
  <div class="max-w-7xl mx-auto px-6 lg:px-14 py-12">
    <div class="max-w-4xl">
    
    <!-- Breadcrumb -->
    <a href={`/${lang}/${chapterSlug}`} class="inline-flex items-center gap-1 text-sm mb-8 no-underline hover:text-primary-400 transition-colors" style="color:var(--text-muted);">
      ← {t(currentLang, "chapter.label")} {chapterNum}: {chapters.find(ch => ch.num === chapterNum)?.title[currentLang]}
    </a>

    <div class="min-h-[400px]">
      {content ? (
        chapterNum === 4 ? (
          <Chapter4Renderer content={content} lang={currentLang} id={sectionSlug!} chapterNum={chapterNum} />
        ) : (
          <SectionRenderer content={content} lang={currentLang} id={sectionSlug!} />
        )
      ) : (
        <!-- No content yet -->
        <div class="prose prose-invert max-w-none">
          <h1 class="text-3xl font-extrabold mb-4" style="color:var(--text-heading);">
            {formatSectionId(section.id)} {section.title[currentLang]}
          </h1>
          <div class="rounded-xl p-8" style={`background:var(--card-bg);border:1px solid var(--card-border);`}>
            <p class="italic text-lg" style="color:var(--text-muted);">
              {currentLang === "ne" ? "सामग्री चाँडै थपिनेछ..." : "Content coming soon..."}
            </p>
          </div>
        </div>
      )}
    </div>

    <!-- Sub-sections if any -->
    {section.children && section.children.length > 0 && (
      <div class="mt-16 rounded-xl p-6" style={`background:var(--card-bg);border:1px solid var(--card-border);`}>
        <h2 class="text-lg font-bold mb-4" style="color:var(--text-heading);">
          {currentLang === "ne" ? "उप-विषयहरू" : "Sub-sections"}
        </h2>
        <div class="space-y-1">
          {section.children.map((child: any) => (
            <a href={`/${lang}/${chapterSlug}/${child.slug}`} class="block py-2 text-sm no-underline hover:text-primary-400 transition-colors" style="color:var(--text-body);">
              <span style="color:var(--text-muted);" class="mr-2">{formatSectionId(child.id)}</span>
              {child.title[currentLang]}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Navigation footer -->
    <div class="flex justify-between items-center mt-12 pt-8" style={`border-top:1px solid var(--border);`}>
      <a href={`/${lang}/${chapterSlug}`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium no-underline transition-all" style="color:var(--text-body);background:var(--card-bg);border:1px solid var(--card-border);">
        {currentLang === "ne" ? "← परिच्छेद विवरणमा फर्कनुहोस्" : "← Back to Chapter"}
      </a>
      <a href={`/${lang}`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium no-underline transition-all" style="color:var(--text-body);background:var(--card-bg);border:1px solid var(--card-border);">
        {t(currentLang, "nav.home")}
      </a>
    </div>
  </div>
</Layout>
