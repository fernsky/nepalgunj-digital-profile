---
import Layout from "../../../layouts/Layout.astro";
import { type Lang, chapters } from "../../../i18n/translations";
import { t, formatSectionId } from "../../../i18n/utils";
import SectionRenderer from "../../../components/SectionRenderer.astro";
import Chapter4Renderer from "../../../components/chapters/4/Chapter4Renderer.astro";


export function getStaticPaths() {
  const paths: any[] = [];
  for (const ch of chapters) {
    paths.push({ params: { lang: "ne", chapter: ch.slug }, props: { chapter: ch } });
    paths.push({ params: { lang: "en", chapter: ch.slug }, props: { chapter: ch } });
  }
  return paths;
}

const lang = Astro.params.lang as Lang;
const { chapter } = Astro.props;
const chapterIdx = chapters.findIndex((c) => c.num === chapter.num);
const prevChapter = chapterIdx > 0 ? chapters[chapterIdx - 1] : null;
const nextChapter = chapterIdx < chapters.length - 1 ? chapters[chapterIdx + 1] : null;

// Load all JSON files statically at build time
const jsonFiles = import.meta.glob('../../../lib/i18n/chapters/**/*.json', { eager: true }) as Record<string, { default: any }>;

// Helper to grab content for a section slug
function getSectionContent(slug: string) {
  const key = `../../../lib/i18n/chapters/${chapter.num}/${slug}/${lang}.json`;
  return jsonFiles[key]?.default ?? null;
}
---

<Layout lang={lang} title={`${t(lang, "chapter.label")} ${chapter.num} - ${chapter.title[lang]}`}>
  <!-- Use standardized container max-width and horizontal padding -->
  <div class="flex flex-col lg:flex-row max-w-7xl mx-auto px-4 sm:px-6 lg:px-14 py-8 sm:py-12 gap-6 sm:gap-10 relative">
    
    <!-- Sidebar / Navigation: Fixed on scroll -->
    <aside class="w-full lg:w-1/4 shrink-0 mt-8 lg:mt-0 lg:sticky lg:top-24 h-max">
      <div class="rounded-xl p-6" style="background:var(--card-bg);border:1px solid var(--card-border);">
        <h2 class="text-xl font-bold mb-4" style="color:var(--text-heading);">
          {lang === "ne" ? "विषयसूची" : "Table of Contents"}
        </h2>
        
        <nav class="space-y-1">
          {chapter.sections.map((section: any) => (
            <div class="mb-4 last:mb-0">
              <a href={`#${section.slug}`} class="block py-2 text-sm font-bold transition-colors no-underline hover:text-primary-400" style="color:var(--text-heading);">
                <span style="color:var(--text-muted);" class="mr-2">{formatSectionId(section.id)}</span>
                {section.title[lang]}
              </a>
              {section.children && section.children.map((child: any) => (
                <a href={`#${child.slug}`} class="block py-1.5 pl-6 text-sm transition-colors no-underline hover:text-primary-400" style="color:var(--text-body);">
                  <span class="mr-2" style="color:var(--text-muted);">{formatSectionId(child.id)}</span>
                  {child.title[lang]}
                </a>
              ))}
            </div>
          ))}
        </nav>
      </div>
    </aside>

    <!-- Main Content Body -->
    <main class="flex-1 min-w-0 min-h-[50vh]">
      <!-- Chapter Hero - Pushed deep enough to align visually -->
      <section class="relative py-12 mb-12 overflow-hidden rounded-3xl" style="background:linear-gradient(135deg, rgba(29,78,216,0.08) 0%, transparent 50%); border: 1px solid rgba(29,78,216,0.1);">
        <div class="relative z-10 px-8">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4" style="background:rgba(29,78,216,0.15);border:1px solid rgba(29,78,216,0.3);">
            <span class="text-primary-400 text-sm font-medium">{t(lang, "chapter.label")} {chapter.num}</span>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4" style="color:var(--text-heading);">
            {chapter.title[lang]}
          </h1>
          <p class="text-lg max-w-2xl" style="color:var(--text-body);">{chapter.description[lang]}</p>
        </div>
      </section>

      <!-- All Sections Rendered Here -->
      {chapter.sections.map((section: any) => {
        const content = getSectionContent(section.slug);
        
        return (
          <>
            {/* Top level section */}
            {chapter.num === 4 ? (
              <Chapter4Renderer content={content} lang={lang} id={section.slug} chapterNum={chapter.num} />
            ) : (
              <SectionRenderer content={content} lang={lang} id={section.slug} />
            )}
            
            {/* Child sections rendered completely flattened inline if any */}
            {section.children && section.children.map((child: any) => {
              const childContent = getSectionContent(child.slug);
              return chapter.num === 4 ? (
                 <Chapter4Renderer content={childContent} lang={lang} id={child.slug} chapterNum={chapter.num} />
              ) : (
                 <SectionRenderer content={childContent} lang={lang} id={child.slug} />
              );
            })}
          </>
        );
      })}

      <!-- Nav between chapters footer -->
      <div class="flex justify-between items-center pt-12 mt-20" style={`border-top:1px solid var(--border);`}>
        {prevChapter ? (
          <a href={`/${lang}/${prevChapter.slug}`} class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold no-underline transition-all hover:-translate-x-1" style="color:var(--text-body);background:var(--card-bg);border:1px solid var(--card-border);">
            ← {t(lang, "chapter.label")} {prevChapter.num}
          </a>
        ) : <div></div>}
        {nextChapter ? (
          <a href={`/${lang}/${nextChapter.slug}`} class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold no-underline transition-all hover:translate-x-1" style="color:var(--text-body);background:var(--card-bg);border:1px solid var(--card-border);">
            {t(lang, "chapter.label")} {nextChapter.num} →
          </a>
        ) : (
          <a href={`/${lang}/annexes`} class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold no-underline transition-all hover:translate-x-1" style="color:var(--text-body);background:var(--card-bg);border:1px solid var(--card-border);">
            {t(lang, "nav.annexes")} →
          </a>
        )}
      </div>
    </main>
  </div>
</Layout>
