---
import Layout from "../../layouts/Layout.astro";
import { type Lang } from "../../i18n/translations";
import { t } from "../../i18n/utils";
import WardMap from "../../components/home/WardMap.astro";

export function getStaticPaths() {
  return [{ params: { lang: "ne" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
---

<Layout lang={lang}>
  <!-- Hero Section - full viewport -->
  <section class="relative min-h-screen flex items-center overflow-hidden" style="background: var(--nav-bg);">
    <!-- Base gradient overlay -->
    <div class="absolute inset-0 z-0">
      <!-- Background pattern -->
      <div class="absolute inset-0 opacity-[0.05]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot; fill=&quot;%23888&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
      <div class="absolute inset-0" style="background:radial-gradient(circle at 10% 30%, rgba(29,78,216,0.15) 0%, transparent 40%);"></div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 px-6 lg:px-14 py-20 w-full max-w-7xl mx-auto flex flex-col lg:flex-row items-center lg:items-start gap-16 -mt-20">
      <div class="w-full lg:w-1/2">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black mb-10 leading-tight" style="color:var(--text-heading);">
          {t(lang, "hero.title")}
        </h1>
        
        <p class="text-lg lg:text-xl mb-12 leading-relaxed opacity-90 max-w-xl" style="color:var(--text-body);">
          {t(lang, "hero.description")}
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="#demographics-map" class="group px-10 py-4 bg-primary-600 hover:bg-primary-500 text-white font-bold rounded-2xl transition-all duration-300 shadow-2xl shadow-primary-900/40 flex items-center gap-3 no-underline border-0 active:scale-95">
             <span>{t(lang, "hero.exploreChapters")}</span>
             <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
             </svg>
          </a>
          <a href={`/${lang}/chapter-1`} class="px-10 py-4 border border-primary-500/30 hover:border-primary-500 hover:bg-primary-500/5 font-bold rounded-2xl transition-all duration-300 no-underline active:scale-95" style="color:var(--text-heading);">
             {lang === 'ne' ? 'विवरण हेर्नुहोस्' : 'View Details'}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Demographics Map Section -->
  <section id="demographics-map" class="py-32 relative overflow-hidden" style="background:var(--nav-bg);">
    <!-- Decoration -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 bg-gradient-to-b from-primary-500/50 to-transparent"></div>
    
    <div class="max-w-7xl mx-auto px-6 lg:px-14">
      <div class="mb-20">
        <h2 class="text-4xl lg:text-5xl font-black mb-6" style="color:var(--text-heading);">
           {lang === 'ne' ? 'नगरको जनसांख्यिक प्रोफाइल' : 'City Demographic Profile'}
        </h2>
        <div class="w-24 h-2 bg-primary-500 rounded-full mb-8 shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
        <p class="text-lg max-w-2xl opacity-80" style="color:var(--text-body);">
           {lang === 'ne' 
             ? "नेपालगंज उप-महानगरपालिकाका २३ वडाहरूको नक्सा र जनसंख्या वितरण आधारभूत जानकारी हेर्नुहोस्। थप विवरणका लागि नक्सामा वडा छान्नुहोस्।" 
             : "Explore the ward-wise population distribution and demographic overview of Nepalgunj's 23 wards. Interact with the map to see details."}
        </p>
      </div>

      <!-- The D3 Map Component -->
      <WardMap lang={lang} />
    </div>
  </section>
</Layout>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 15s linear infinite;
  }
</style>
