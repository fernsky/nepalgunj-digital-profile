---
import { type Lang } from "../i18n/translations";
import { t, getChapters, getAnnexes, getAlternateUrl, formatSectionId, toNepaliDigits } from "../i18n/utils";

interface Props { lang: Lang; currentPath: string; noSpacer?: boolean; }
const { lang, currentPath, noSpacer = false } = Astro.props;
const chapters = getChapters();
const annexItems = getAnnexes();
const alternateLang: Lang = lang === "ne" ? "en" : "ne";
const alternateUrl = getAlternateUrl(currentPath, alternateLang);
const cleanTitle = (title: string) => title.replace(/^[\d\u0966-\u096F\.]+\s*/, '');
---

<nav id="main-nav" class="absolute top-0 left-0 right-0 z-50 border-b" style={`background:transparent;border-color:rgba(255,255,255,0.4);`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-14">
    <div class="flex items-center justify-between h-24">
      <div class="flex items-center gap-8 min-w-0">
        <!-- Logo -->
        <a href={`/${lang}/`} class="flex items-center gap-3 sm:gap-4 no-underline group shrink-0">
          <img src="/coat of arms.png" alt="Coat of Arms" class="w-12 h-12 sm:w-16 sm:h-16 object-contain" />
          <div class="flex flex-col leading-tight">
            <span class="font-bold text-lg sm:text-xl" style="color:var(--text-heading);">{t(lang, "site.name")}</span>
            <span class="text-xs sm:text-sm hidden sm:block" style="color:var(--text-heading); opacity: 0.8;">{t(lang, "site.subtitle")}</span>
          </div>
        </a>

        <!-- Desktop Nav Links (hidden on mobile) -->
        <div class="hidden lg:flex items-center gap-1">
          <a href={`/${lang}/`} class="px-4 py-2 text-base font-semibold rounded-md transition-all duration-200 no-underline" style={`color:var(--text-heading);`}
            onmouseover="this.style.background='var(--hover-bg)'"
            onmouseout="this.style.background='transparent'"
          >
            {t(lang, "nav.home")}
          </a>

          <a href={`/${lang}/profile`} class="px-4 py-2 text-base font-semibold rounded-md transition-all duration-200 no-underline" style={`color:var(--text-heading);`}
            onmouseover="this.style.background='var(--hover-bg)'"
            onmouseout="this.style.background='transparent'"
          >
            {lang === 'ne' ? 'पूर्ण प्रोफाइल' : 'Full Profile'}
          </a>

          <div class="relative" id="chapters-dropdown-container">
            <button id="chapters-btn" class="px-4 py-2 text-base font-semibold rounded-md transition-all duration-200 flex items-center gap-1.5 cursor-pointer border-0" style={`color:var(--text-heading);background:transparent;`}>
              {t(lang, "nav.chapters")}
              <svg id="chapters-chevron" class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <!-- Mega Dropdown -->
            <div id="chapters-mega-dropdown" class="absolute top-full right-0 lg:left-1/2 lg:-translate-x-1/2 mt-2 w-[860px] rounded-lg shadow-2xl opacity-0 invisible translate-y-2 transition-all duration-300 overflow-hidden" style={`background:var(--dropdown-bg);border:1px solid var(--border);`}>              <div class="flex">
                <!-- Left Panel -->
                <div class="w-[260px] py-3 max-h-[480px] overflow-y-auto border-r" style={`background:var(--dropdown-sidebar);border-color:var(--border);`}>
                  {chapters.map((chapter) => (
                    <a href={`/${lang}/${chapter.slug}`} class="chapter-tab block w-full text-left px-5 py-3 text-sm transition-all duration-200 border-l-3 border-transparent no-underline cursor-pointer" data-chapter={chapter.num} style={`color:var(--text-body);`}>
                      <span class="text-xs font-medium" style="color:var(--text-muted);">{t(lang, "chapter.label")} {lang === "ne" ? toNepaliDigits(chapter.num) : chapter.num}:</span><br />
                      <span class="font-medium">{chapter.title[lang]}</span>
                    </a>
                  ))}
                  <div class="mt-1 pt-1" style={`border-top:1px solid var(--border);`}>
                    <a href={`/${lang}/annexes`} class="chapter-tab block w-full text-left px-5 py-3 text-sm transition-all duration-200 border-l-3 border-transparent no-underline cursor-pointer" data-chapter="annexes" style={`color:var(--text-body);`}>
                      <span class="font-medium">{t(lang, "nav.annexes")}</span>
                    </a>
                  </div>
                </div>

                <!-- Right Panel -->
                <div class="flex-1 py-4 px-6 min-h-[350px] max-h-[480px] overflow-y-auto">
                  {chapters.map((chapter) => (
                    <div class="chapter-panel hidden" data-chapter-panel={chapter.num}>
                      <h3 class="text-base font-bold mb-1" style="color:var(--text-heading);">{chapter.description[lang]}</h3>
                      <div class="h-px my-3" style={`background:var(--border);`}></div>
                      <div class="grid grid-cols-2 gap-x-6 gap-y-0.5">
                        {chapter.sections.map((section) => (
                          <div>
                            <a href={`/${lang}/${chapter.slug}#${section.slug}`} class="block py-1.5 text-sm transition-colors duration-200 no-underline hover:text-primary-400" style={`color:var(--text-body);`}>
                              <span style="color:var(--text-muted);" class="mr-1.5">{formatSectionId(section.id, lang)}</span>
                              {cleanTitle(section.title[lang])}
                            </a>
                            {section.children && section.children.map((child) => (
                              <a href={`/${lang}/${chapter.slug}#${child.slug}`} class="block py-1 pl-5 text-xs transition-colors duration-200 no-underline hover:text-primary-400" style={`color:var(--text-muted);`}>
                                <span class="mr-1">{formatSectionId(child.id, lang)}</span>
                                {cleanTitle(child.title[lang])}
                              </a>
                            ))}
                          </div>
                        ))}
                      </div>
                      <div class="mt-4 pt-3" style={`border-top:1px solid var(--border);`}>
                        <a href={`/${lang}/${chapter.slug}`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary-500 hover:text-primary-400 transition-colors duration-200 no-underline">
                          {t(lang, "nav.viewFullChapter")} →
                        </a>
                      </div>
                    </div>
                  ))}
                  <div class="chapter-panel hidden" data-chapter-panel="annexes">
                    <h3 class="text-base font-bold mb-1" style="color:var(--text-heading);">{t(lang, "nav.annexes")}</h3>
                    <div class="h-px my-3" style={`background:var(--border);`}></div>
                    <div class="space-y-1">
                      {annexItems.map((annex) => (
                        <a href={`/${lang}/annexes#${annex.slug}`} class="block py-2 text-sm transition-colors duration-200 no-underline hover:text-primary-400" style={`color:var(--text-body);`}>{annex.title[lang]}</a>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>


      <!-- Right: Theme + Lang + Mobile Hamburger -->
      <div class="flex items-center gap-2 sm:gap-3">
        <button id="theme-toggle" class="p-2 rounded-md transition-all duration-200 cursor-pointer border-0" style="color:var(--text-muted);background:transparent;" aria-label="Toggle theme">
          <svg id="theme-icon-sun" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
          <svg id="theme-icon-moon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
        </button>
        <div class="flex items-center">
          <a href={lang === "ne" ? currentPath : getAlternateUrl(currentPath, "ne")}
            class:list={["px-2.5 py-1.5 text-xs sm:text-sm font-medium rounded-l-lg border transition-all duration-200 no-underline", lang === "ne" ? "bg-primary-700 text-white border-primary-600" : "border-gray-600"]}
            style={lang !== "ne" ? "color:var(--text-muted);background:var(--card-bg);" : ""}
          >ने</a>
          <a href={lang === "en" ? currentPath : getAlternateUrl(currentPath, "en")}
            class:list={["px-2.5 py-1.5 text-xs sm:text-sm font-medium rounded-r-lg border-t border-b border-r transition-all duration-200 no-underline", lang === "en" ? "bg-primary-700 text-white border-primary-600" : "border-gray-600"]}
            style={lang !== "en" ? "color:var(--text-muted);background:var(--card-bg);" : ""}
          >En</a>
        </div>

        <!-- Mobile Hamburger Button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-md transition-all duration-200 cursor-pointer border-0" style="color:var(--text-heading);background:transparent;" aria-label="Open menu">
          <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu-overlay" class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm opacity-0 invisible transition-all duration-300 lg:hidden"></div>

<!-- Mobile Slide-out Drawer -->
<div id="mobile-drawer" class="fixed top-0 right-0 z-50 h-full w-[85vw] max-w-[360px] translate-x-full transition-transform duration-300 ease-out overflow-y-auto lg:hidden" style="background:var(--dropdown-bg);">
  <div class="p-5 pt-20">
    <!-- Main Links -->
    <div class="space-y-1 mb-6">
      <a href={`/${lang}/`} class="block px-4 py-3 text-base font-medium rounded-xl no-underline transition-colors" style="color:var(--text-heading);">
        {t(lang, "nav.home")}
      </a>
      <a href={`/${lang}/profile`} class="block px-4 py-3 text-base font-bold rounded-xl no-underline transition-colors bg-primary-600 text-white">
        {lang === 'ne' ? 'पूर्ण प्रोफाइल हेर्नुहोस्' : 'View Full Profile'}
      </a>
    </div>

    <!-- Chapters List with Accordions -->
    <div class="mb-4">
      <h3 class="px-4 text-xs font-bold uppercase tracking-wider mb-3 opacity-50" style="color:var(--text-muted);">
        {t(lang, "nav.chapters")}
      </h3>
      <div class="space-y-2">
        {chapters.map((chapter) => (
          <div class="mobile-accordion-item">
            <button 
              class="mobile-accordion-btn w-full flex items-center justify-between px-4 py-4 rounded-xl no-underline transition-all border-0 cursor-pointer" 
              style="color:var(--text-body); background: var(--card-bg); border: 1px solid var(--card-border);"
              data-chapter={chapter.num}
            >
              <div class="text-left">
                <span class="text-[10px] font-bold block uppercase tracking-tight opacity-60" style="color:var(--text-muted);">{t(lang, "chapter.label")} {lang === "ne" ? toNepaliDigits(chapter.num) : chapter.num}</span>
                <span class="font-bold text-sm tracking-tight">{chapter.title[lang]}</span>
              </div>
              <svg class="w-5 h-5 transition-transform duration-300 chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="mobile-accordion-content hidden px-2 py-2 space-y-1">
              {chapter.sections.map((section) => (
                <div>
                   <a href={`/${lang}/${chapter.slug}#${section.slug}`} class="mobile-section-link block px-4 py-2 text-sm rounded-lg no-underline transition-colors" style="color:var(--text-body);">
                    <span class="opacity-50 mr-2 font-mono text-xs">{formatSectionId(section.id, lang)}</span>
                    {cleanTitle(section.title[lang])}
                  </a>
                  {section.children && section.children.map((child) => (
                    <a href={`/${lang}/${chapter.slug}#${child.slug}`} class="mobile-section-link block px-4 py-1.5 pl-10 text-xs rounded-lg no-underline transition-colors" style="color:var(--text-muted);">
                       <span class="opacity-40 mr-2 font-mono">{formatSectionId(child.id, lang)}</span>
                       {cleanTitle(child.title[lang])}
                    </a>
                  ))}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>


    <!-- Annexes -->
    <div class="pt-4" style={`border-top:1px solid var(--border);`}>
      <a href={`/${lang}/annexes`} class="block px-4 py-3 rounded-xl no-underline transition-colors text-sm font-medium" style="color:var(--text-body);">
        {t(lang, "nav.annexes")}
      </a>
    </div>
  </div>
</div>

{!noSpacer && <div class="h-16"></div>}

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Desktop mega menu
    const btn = document.getElementById("chapters-btn");
    const dropdown = document.getElementById("chapters-mega-dropdown");
    const chevron = document.getElementById("chapters-chevron");
    const container = document.getElementById("chapters-dropdown-container");
    const tabs = document.querySelectorAll<HTMLElement>(".chapter-tab");
    const panels = document.querySelectorAll<HTMLElement>(".chapter-panel");
    let isOpen = false;

    function activate(key: string) {
      tabs.forEach((t) => {
        const k = t.dataset.chapter || "";
        if (k === key) { t.style.borderLeftColor = "#3b82f6"; t.style.color = "var(--text-heading)"; t.style.background = "var(--hover-bg)"; }
        else { t.style.borderLeftColor = "transparent"; t.style.color = "var(--text-body)"; t.style.background = "transparent"; }
      });
      panels.forEach((p) => { p.classList.toggle("hidden", p.dataset.chapterPanel !== key); });
    }

    function open() { 
      if (isOpen) return; 
      isOpen = true; 
      dropdown?.classList.remove("opacity-0", "invisible", "translate-y-2"); 
      dropdown?.classList.add("opacity-100", "visible", "translate-y-0"); 
      chevron?.classList.add("rotate-180"); 

      // On open, activate the tab corresponding to current path if possible
      const pathParts = window.location.pathname.split('/');
      const currentChapterSlug = pathParts[pathParts.length - 1];
      const activeTab = Array.from(tabs).find(t => t.getAttribute('href')?.includes(currentChapterSlug));
      const key = activeTab?.dataset.chapter || "1";
      activate(key); 
    }
    function close() { if (!isOpen) return; isOpen = false; dropdown?.classList.add("opacity-0", "invisible", "translate-y-2"); dropdown?.classList.remove("opacity-100", "visible", "translate-y-0"); chevron?.classList.remove("rotate-180"); }

    btn?.addEventListener("click", (e) => { e.preventDefault(); e.stopPropagation(); isOpen ? close() : open(); });
    document.addEventListener("click", (e) => { if (container && !container.contains(e.target as Node)) close(); });
    tabs.forEach((tab) => { tab.addEventListener("mouseenter", () => activate(tab.dataset.chapter || "")); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") { close(); closeMobile(); } });

    // Mobile menu
    const mobileBtn = document.getElementById("mobile-menu-btn");
    const overlay = document.getElementById("mobile-menu-overlay");
    const drawer = document.getElementById("mobile-drawer");
    const hamburger = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");
    let mobileOpen = false;

    function openMobile() {
      if (mobileOpen) return;
      mobileOpen = true;
      document.body.style.overflow = "hidden";
      overlay?.classList.remove("opacity-0", "invisible");
      overlay?.classList.add("opacity-100", "visible");
      drawer?.classList.remove("translate-x-full");
      drawer?.classList.add("translate-x-0");
      hamburger?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");

      // Expand current chapter accordion
      const currentChapterNumber = window.location.pathname.match(/\/\w{2}\/chapter-(\d+)/)?.[1];
      if (currentChapterNumber) {
        const activeBtn = Array.from(accordionBtns).find(b => b.dataset.chapter === currentChapterNumber) as HTMLElement;
        if (activeBtn) {
          const content = activeBtn.nextElementSibling as HTMLElement;
          if (content.classList.contains('hidden')) activeBtn.click();
        }
      }
    }

    function closeMobile() {
      if (!mobileOpen) return;
      mobileOpen = false;
      document.body.style.overflow = "";
      overlay?.classList.add("opacity-0", "invisible");
      overlay?.classList.remove("opacity-100", "visible");
      drawer?.classList.add("translate-x-full");
      drawer?.classList.remove("translate-x-0");
      hamburger?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    }

    mobileBtn?.addEventListener("click", () => { mobileOpen ? closeMobile() : openMobile(); });
    overlay?.addEventListener("click", closeMobile);

    // Close mobile menu on clicking primary links
    drawer?.querySelectorAll(":scope > div > div > a").forEach((link) => {
      link.addEventListener("click", closeMobile);
    });

    // Mobile menu accordions
    const accordionBtns = document.querySelectorAll<HTMLElement>(".mobile-accordion-btn");
    
    accordionBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const content = btn.nextElementSibling as HTMLElement;
        const chevron = btn.querySelector(".chevron") as HTMLElement;
        const isOpen = !content.classList.contains("hidden");

        // Close all other accordions
        accordionBtns.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.nextElementSibling?.classList.add("hidden");
            otherBtn.querySelector(".chevron")?.classList.remove("rotate-180");
            (otherBtn as HTMLElement).style.background = "var(--card-bg)";
          }
        });

        // Toggle current
        content.classList.toggle("hidden");
        chevron.classList.toggle("rotate-180");
        btn.style.background = isOpen ? "var(--card-bg)" : "var(--hover-bg)";
      });
    });

    // Hover and active effects for mobile sections
    drawer?.querySelectorAll(".mobile-section-link").forEach((link) => {
      link.addEventListener("mouseenter", () => { (link as HTMLElement).style.background = "var(--hover-bg)"; });
      link.addEventListener("mouseleave", () => { (link as HTMLElement).style.background = "transparent"; });
      link.addEventListener("click", closeMobile);
    });

    // Theme toggle
    const themeBtn = document.getElementById("theme-toggle");
    const sun = document.getElementById("theme-icon-sun");
    const moon = document.getElementById("theme-icon-moon");

    function setTheme(theme: string) {
      if (theme === "light") { document.documentElement.classList.add("light"); sun?.classList.add("hidden"); moon?.classList.remove("hidden"); }
      else { document.documentElement.classList.remove("light"); sun?.classList.remove("hidden"); moon?.classList.add("hidden"); }
      localStorage.setItem("theme", theme);
    }
    setTheme(localStorage.getItem("theme") || "dark");
    themeBtn?.addEventListener("click", () => { setTheme(document.documentElement.classList.contains("light") ? "dark" : "light"); });
  });
</script>
