---
import { type Lang } from "../i18n/translations";
import { t, getChapters, getAnnexes, getAlternateUrl, formatSectionId } from "../i18n/utils";

interface Props { lang: Lang; currentPath: string; }
const { lang, currentPath } = Astro.props;
const chapters = getChapters();
const annexItems = getAnnexes();
const alternateLang: Lang = lang === "ne" ? "en" : "ne";
const alternateUrl = getAlternateUrl(currentPath, alternateLang);
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b" style={`background:var(--nav-bg);border-color:var(--border);`}>
  <div class="max-w-7xl mx-auto px-6 lg:px-14">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={`/${lang}/`} class="flex items-center gap-3 no-underline group">
        <div class="w-10 h-10 rounded-full bg-primary-700 flex items-center justify-center border-2 border-primary-500">
          <svg viewBox="0 0 40 40" class="w-8 h-8">
            <circle cx="20" cy="20" r="18" fill="#1d4ed8" stroke="#60a5fa" stroke-width="1.5"/>
            <text x="20" y="25" text-anchor="middle" fill="white" font-size="14" font-weight="bold">न</text>
          </svg>
        </div>
        <div class="flex flex-col leading-tight">
          <span class="font-bold text-lg" style="color:var(--text-heading);">{t(lang, "site.name")}</span>
          <span class="text-xs" style="color:var(--text-muted);">{t(lang, "site.subtitle")}</span>
        </div>
      </a>

      <!-- Nav Links -->
      <div class="flex items-center gap-1">
        <a href={`/${lang}/`} class="px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 no-underline" style={`color:var(--text-body);`}
          onmouseover="this.style.color='var(--text-heading)';this.style.background='var(--hover-bg)'"
          onmouseout="this.style.color='var(--text-body)';this.style.background='transparent'"
        >
          {t(lang, "nav.home")}
        </a>

        <div class="relative" id="chapters-dropdown-container">
          <button id="chapters-btn" class="px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 flex items-center gap-1.5 cursor-pointer border-0" style={`color:var(--text-body);background:transparent;`}>
            {t(lang, "nav.chapters")}
            <svg id="chapters-chevron" class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Mega Dropdown - positioned below Chapters button -->
          <div id="chapters-mega-dropdown" class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-[860px] rounded-xl shadow-2xl opacity-0 invisible translate-y-2 transition-all duration-300 overflow-hidden" style={`background:var(--dropdown-bg);border:1px solid var(--border);`}>
            <div class="flex">
              <!-- Left Panel -->
              <div class="w-[260px] py-3 max-h-[480px] overflow-y-auto border-r" style={`background:var(--dropdown-sidebar);border-color:var(--border);`}>
                {chapters.map((chapter) => (
                  <a href={`/${lang}/${chapter.slug}`} class="chapter-tab block w-full text-left px-5 py-3 text-sm transition-all duration-200 border-l-3 border-transparent no-underline cursor-pointer" data-chapter={chapter.num} style={`color:var(--text-body);`}>
                    <span class="text-xs font-medium" style="color:var(--text-muted);">{t(lang, "chapter.label")} {chapter.num}:</span><br />
                    <span class="font-medium">{chapter.title[lang]}</span>
                  </a>
                ))}
                <div class="mt-1 pt-1" style={`border-top:1px solid var(--border);`}>
                  <a href={`/${lang}/annexes`} class="chapter-tab block w-full text-left px-5 py-3 text-sm transition-all duration-200 border-l-3 border-transparent no-underline cursor-pointer" data-chapter="annexes" style={`color:var(--text-body);`}>
                    <span class="font-medium">{t(lang, "nav.annexes")}</span>
                  </a>
                </div>
              </div>

              <!-- Right Panel -->
              <div class="flex-1 py-4 px-6 min-h-[350px] max-h-[480px] overflow-y-auto">
                {chapters.map((chapter) => (
                  <div class="chapter-panel hidden" data-chapter-panel={chapter.num}>
                    <h3 class="text-base font-bold mb-1" style="color:var(--text-heading);">{chapter.description[lang]}</h3>
                    <div class="h-px my-3" style={`background:var(--border);`}></div>
                    <div class="grid grid-cols-2 gap-x-6 gap-y-0.5">
                      {chapter.sections.map((section) => (
                        <div>
                          <a href={`/${lang}/${chapter.slug}#${section.slug}`} class="block py-1.5 text-sm transition-colors duration-200 no-underline hover:text-primary-400" style={`color:var(--text-body);`}>
                            <span style="color:var(--text-muted);" class="mr-1.5">{formatSectionId(section.id)}</span>
                            {section.title[lang]}
                          </a>
                          {section.children && section.children.map((child) => (
                            <a href={`/${lang}/${chapter.slug}#${child.slug}`} class="block py-1 pl-5 text-xs transition-colors duration-200 no-underline hover:text-primary-400" style={`color:var(--text-muted);`}>
                              <span class="mr-1">{formatSectionId(child.id)}</span>
                              {child.title[lang]}
                            </a>
                          ))}
                        </div>
                      ))}
                    </div>
                    <div class="mt-4 pt-3" style={`border-top:1px solid var(--border);`}>
                      <a href={`/${lang}/${chapter.slug}`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary-500 hover:text-primary-400 transition-colors duration-200 no-underline">
                        {t(lang, "nav.viewFullChapter")} →
                      </a>
                    </div>
                  </div>
                ))}
                <div class="chapter-panel hidden" data-chapter-panel="annexes">
                  <h3 class="text-base font-bold mb-1" style="color:var(--text-heading);">{t(lang, "nav.annexes")}</h3>
                  <div class="h-px my-3" style={`background:var(--border);`}></div>
                  <div class="space-y-1">
                    {annexItems.map((annex) => (
                      <a href={`/${lang}/annexes#${annex.id}`} class="block py-2 text-sm transition-colors duration-200 no-underline hover:text-primary-400" style={`color:var(--text-body);`}>{annex.title[lang]}</a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Theme + Lang -->
      <div class="flex items-center gap-3">
        <button id="theme-toggle" class="p-2 rounded-lg transition-all duration-200 cursor-pointer border-0" style="color:var(--text-muted);background:transparent;" aria-label="Toggle theme">
          <svg id="theme-icon-sun" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
          <svg id="theme-icon-moon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
        </button>
        <div class="flex items-center">
          <a href={lang === "ne" ? currentPath : getAlternateUrl(currentPath, "ne")}
            class:list={["px-3 py-1.5 text-sm font-medium rounded-l-lg border transition-all duration-200 no-underline", lang === "ne" ? "bg-primary-700 text-white border-primary-600" : "border-gray-600"]}
            style={lang !== "ne" ? "color:var(--text-muted);background:var(--card-bg);" : ""}
          >ने</a>
          <a href={lang === "en" ? currentPath : getAlternateUrl(currentPath, "en")}
            class:list={["px-3 py-1.5 text-sm font-medium rounded-r-lg border-t border-b border-r transition-all duration-200 no-underline", lang === "en" ? "bg-primary-700 text-white border-primary-600" : "border-gray-600"]}
            style={lang !== "en" ? "color:var(--text-muted);background:var(--card-bg);" : ""}
          >En</a>
        </div>
      </div>
    </div>
  </div>
</nav>
<div class="h-16"></div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("chapters-btn");
    const dropdown = document.getElementById("chapters-mega-dropdown");
    const chevron = document.getElementById("chapters-chevron");
    const container = document.getElementById("chapters-dropdown-container");
    const tabs = document.querySelectorAll<HTMLElement>(".chapter-tab");
    const panels = document.querySelectorAll<HTMLElement>(".chapter-panel");
    let isOpen = false;

    function activate(key: string) {
      tabs.forEach((t) => {
        const k = t.dataset.chapter || "";
        if (k === key) { t.style.borderLeftColor = "#3b82f6"; t.style.color = "var(--text-heading)"; t.style.background = "var(--hover-bg)"; }
        else { t.style.borderLeftColor = "transparent"; t.style.color = "var(--text-body)"; t.style.background = "transparent"; }
      });
      panels.forEach((p) => { p.classList.toggle("hidden", p.dataset.chapterPanel !== key); });
    }

    function open() { if (isOpen) return; isOpen = true; dropdown?.classList.remove("opacity-0", "invisible", "translate-y-2"); dropdown?.classList.add("opacity-100", "visible", "translate-y-0"); chevron?.classList.add("rotate-180"); activate("1"); }
    function close() { if (!isOpen) return; isOpen = false; dropdown?.classList.add("opacity-0", "invisible", "translate-y-2"); dropdown?.classList.remove("opacity-100", "visible", "translate-y-0"); chevron?.classList.remove("rotate-180"); }

    btn?.addEventListener("click", (e) => { e.preventDefault(); e.stopPropagation(); isOpen ? close() : open(); });
    document.addEventListener("click", (e) => { if (container && !container.contains(e.target as Node)) close(); });
    tabs.forEach((tab) => { tab.addEventListener("mouseenter", () => activate(tab.dataset.chapter || "")); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });

    // Theme toggle
    const themeBtn = document.getElementById("theme-toggle");
    const sun = document.getElementById("theme-icon-sun");
    const moon = document.getElementById("theme-icon-moon");

    function setTheme(theme: string) {
      if (theme === "light") { document.documentElement.classList.add("light"); sun?.classList.add("hidden"); moon?.classList.remove("hidden"); }
      else { document.documentElement.classList.remove("light"); sun?.classList.remove("hidden"); moon?.classList.add("hidden"); }
      localStorage.setItem("theme", theme);
    }
    setTheme(localStorage.getItem("theme") || "dark");
    themeBtn?.addEventListener("click", () => { setTheme(document.documentElement.classList.contains("light") ? "dark" : "light"); });
  });
</script>
