  { id: 20, name: { ne: "वडा २०", en: "Ward 20" }, pop: 8344, households: 1600 },
  { id: 21, name: { ne: "वडा २१", en: "Ward 21" }, pop: 4100, households: 780 },
  { id: 22, name: { ne: "वडा २२", en: "Ward 22" }, pop: 3800, households: 720 },
  { id: 23, name: { ne: "वडा २३", en: "Ward 23" }, pop: 3000, households: 580 },
