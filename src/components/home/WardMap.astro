function generateStylizedPath(i: number) {
  // Use pre-defined shapes to avoid "rectangular boxes"
  return wardShapes[i] || "M0,0 L10,0 L10,10 Z";
}
---

<div class="relative w-full" id="map-section" style="min-height: 600px;">
  <div class="flex flex-col lg:flex-row gap-16 items-center lg:items-center">
    <!-- Left Stats -->
    <div class="w-full lg:w-1/3 flex flex-col gap-10">
      <div class="map-stat-card">
        <h3 class="text-5xl font-black mb-2 leading-none" style="color:var(--text-heading);">164,444</h3>
        <p class="text-xs tracking-[0.2em] uppercase font-bold text-primary-400">Total Population / कुल जनसंख्या</p>
      </div>
      
      <div class="map-stat-card">
        <h3 class="text-5xl font-black mb-2 leading-none" style="color:var(--text-heading);">82,755 / 81,689</h3>
        <p class="text-xs tracking-[0.2em] uppercase font-bold text-primary-400">Male / Female</p>
      </div>

      <div class="map-stat-card">
         <h3 class="text-5xl font-black mb-2 leading-none" style="color:var(--text-heading);">76.24%</h3>
         <p class="text-xs tracking-[0.2em] uppercase font-bold text-primary-400">Literacy Rate / साक्षरता दर</p>
      </div>

      <div id="hover-info-box" class="p-6 rounded-2xl border border-primary-500/10 bg-primary-500/5 backdrop-blur-xl opacity-0 transition-opacity duration-300">
        <h4 id="ward-name" class="text-2xl font-black mb-1" style="color:var(--text-heading);">-</h4>
        <div class="space-y-2 mt-4">
           <div class="flex justify-between text-sm"><span style="color:var(--text-muted)">Population:</span><span id="ward-pop-val" class="font-bold text-primary-400">-</span></div>
           <div class="flex justify-between text-sm"><span style="color:var(--text-muted)">Households:</span><span id="ward-house-val" class="font-bold text-primary-400">-</span></div>
        </div>
      </div>
    </div>

    <!-- Right Map Container - Explicit Dimensions -->
    <div class="w-full lg:w-2/3 relative flex justify-center">
      <div class="relative w-full aspect-square max-w-[650px]" id="d3-map-wrapper">
         <svg id="main-map-svg" viewBox="0 0 600 600" class="w-full h-full overflow-visible">
            <g id="wards-group">
               {wardData.map((ward, i) => (
                  <g class="ward-group" data-ward-id={ward.id}>
                    <path 
                      id={`ward-path-${ward.id}`}
                      class="ward-path cursor-pointer transition-all duration-300" 
                      d={generateStylizedPath(i)}
                      fill="#2563eb"
                      fill-opacity="0.1"
                      stroke="#3b82f6"
                      stroke-width="1.5"
                      stroke-opacity="0.5"
                    />
                    <text
                      class="ward-label pointer-events-none font-bold text-[10px]"
                      x={80 + (i % 4) * 110 + 20}
                      y={80 + Math.floor(i / 4) * 90 + 10}
                      fill="var(--text-heading)"
                      fill-opacity="0"
                      text-anchor="middle"
                    >
                      {ward.id}
                    </text>
                  </g>
               ))}
            </g>
         </svg>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ wardData, lang }}>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof d3 === 'undefined') {
        console.error('D3 not loaded');
        return;
    }

    const svg = d3.select('#main-map-svg');
    const minPop = 3000, maxPop = 13200;

    // Animation
    d3.selectAll('.ward-path')
      .each(function(d, i) {
          const ward = wardData[i];
          const opacity = 0.15 + ((ward.pop - minPop) / (maxPop - minPop)) * 0.7;
          const path = d3.select(this);
          const length = this.getTotalLength();
          path.attr('stroke-dasharray', length)
              .attr('stroke-dashoffset', length)
              .transition()
              .duration(1200)
              .delay(i * 60)
              .attr('stroke-dashoffset', 0)
              .attr('fill-opacity', opacity);
      });

    d3.selectAll('.ward-label')
      .transition()
      .duration(1000)
      .delay((d, i) => i * 60 + 500)
      .attr('fill-opacity', 0.8);

    // Interaction
    const infoBox = document.getElementById('hover-info-box');
    const nameLabel = document.getElementById('ward-name');
    const popVal = document.getElementById('ward-pop-val');
    const houseVal = document.getElementById('ward-house-val');

    d3.selectAll('.ward-group')
      .on('mouseenter', function(event) {
          const id = parseInt(this.getAttribute('data-ward-id'));
          const ward = wardData.find(w => w.id === id);
          
          d3.select(this).select('path')
            .transition().duration(200)
            .attr('fill-opacity', 0.9)
            .attr('stroke-opacity', 1)
            .attr('transform', 'scale(1.05)');

          infoBox.style.opacity = '1';
          nameLabel.textContent = ward.name[lang];
          popVal.textContent = ward.pop.toLocaleString();
          houseVal.textContent = ward.households.toLocaleString();
      })
      .on('mouseleave', function() {
          const id = parseInt(this.getAttribute('data-ward-id'));
          const ward = wardData.find(w => w.id === id);
          const opacity = 0.15 + ((ward.pop - minPop) / (maxPop - minPop)) * 0.7;

          d3.select(this).select('path')
            .transition().duration(400)
            .attr('fill-opacity', opacity)
            .attr('stroke-opacity', 0.5)
            .attr('transform', 'scale(1)');
      });
  });
</script>

<style>
  .map-stat-card {
    border-left: 5px solid #2563eb;
    padding-left: 2rem;
  }
  .ward-path {
     transform-origin: center center;
     vector-effect: non-scaling-stroke;
  }
</style>
