  { id: 5, name: { ne: "वडा ५", en: "Ward 5" }, pop: 7200, households: 1400 },
  { id: 6, name: { ne: "वडा ६", en: "Ward 6" }, pop: 5900, households: 1150 },
  { id: 7, name: { ne: "वडा ७", en: "Ward 7" }, pop: 10800, households: 2050 },
  { id: 8, name: { ne: "वडा ८", en: "Ward 8" }, pop: 12500, households: 2350 },
  { id: 9, name: { ne: "वडा ९", en: "Ward 9" }, pop: 6100, households: 1200 },
  { id: 10, name: { ne: "वडा १०", en: "Ward 10" }, pop: 13200, households: 2500 },
  { id: 11, name: { ne: "वडा ११", en: "Ward 11" }, pop: 10500, households: 1950 },
