const wardShapes = [
  "M150,120 L180,110 L210,130 L190,160 L160,170 Z", // 1
  "M210,130 L240,120 L270,140 L250,170 L210,180 Z", // 2
  "M270,140 L300,130 L330,150 L310,180 L270,190 Z", // 3
  "M330,150 L360,140 L390,160 L370,190 L330,200 Z", // 4
  "M140,170 L190,160 L200,200 L150,210 Z", // 5
  "M200,180 L250,170 L260,210 L210,220 Z", // 6
  "M260,190 L310,180 L320,220 L270,230 Z", // 7
  "M310,200 L370,190 L380,230 L320,240 Z", // 8
  "M130,210 L180,200 L170,250 L120,260 Z", // 9
  "M180,220 L230,210 L220,260 L170,270 Z", // 10
  "M230,230 L280,220 L270,270 L220,280 Z", // 11
