---
interface Props {
  content: any;
}
const { content } = Astro.props;
---
<div class="prose prose-invert max-w-none">
  <h2 class="text-3xl font-extrabold mb-6" style="color:var(--text-heading);">{content.sectionNumber} {content.title}</h2>
  
  <p class="text-lg mb-10 leading-relaxed" style="color:var(--text-body);">
    {content.description}
  </p>

  <div class="space-y-8">
    {content.subsections?.map((sub: any) => (
      <div class="p-8 rounded-2xl" style="background:var(--card-bg);border:1px solid var(--card-border);">
        <h3 class="text-2xl font-bold mb-4" style="color:var(--text-heading);">{sub.title}</h3>
        <p class="text-lg leading-relaxed mb-4" style="color:var(--text-body);">
          {sub.content}
        </p>
        {sub.extra && (
          <p class="text-lg leading-relaxed mt-6 pt-6 border-t" style="color:var(--text-body);border-color:var(--border);">
            {sub.extra}
          </p>
        )}
      </div>
    ))}
  </div>
</div>
