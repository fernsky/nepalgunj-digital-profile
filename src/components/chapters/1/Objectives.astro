---
interface Props {
  content: any;
}
const { content } = Astro.props;
---
<div class="prose prose-invert max-w-none">
  <h2 class="text-3xl font-extrabold mb-6" style="color:var(--text-heading);">{content.sectionNumber} {content.title}</h2>
  
  <p class="text-lg mb-8 leading-relaxed" style="color:var(--text-body);">
    {content.description}
  </p>

  <div class="space-y-4">
    {content.list?.map((item: string) => (
      <div class="flex gap-4 p-4 rounded-xl" style="background:var(--card-bg);border:1px solid var(--card-border);">
        <div class="text-lg leading-relaxed" style="color:var(--text-body);">
          {item}
        </div>
      </div>
    ))}
  </div>
</div>
