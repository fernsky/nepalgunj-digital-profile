---
interface Props {
  content: any;
}
const { content } = Astro.props;
---
<div class="prose prose-invert max-w-none">
  <h2 class="text-3xl font-extrabold mb-6" style="color:var(--text-heading);">{content.sectionNumber} {content.title}</h2>
  
  <p class="text-lg mb-8 leading-relaxed" style="color:var(--text-body);">
    {content.description}
  </p>

  <!-- Bullet points / methodology overview -->
  {content.bullet_points && content.bullet_points.length > 0 && (
    <div class="space-y-5 mb-14">
      {content.bullet_points.map((p: string) => (
        <div class="flex gap-4 p-5 rounded-xl" style="background:var(--card-bg);border:1px solid var(--card-border);">
          <div class="w-2 h-2 mt-2.5 rounded-full shrink-0" style="background:var(--primary-400);"></div>
          <p class="text-lg leading-relaxed m-0" style="color:var(--text-body);">{p}</p>
        </div>
      ))}
    </div>
  )}

  <!-- Sub-stages (1.4.1 to 1.4.7) -->
  {content.sub_stages && content.sub_stages.length > 0 && (
    <div class="space-y-10">
      {content.sub_stages.map((stage: any) => (
        <div class="p-8 rounded-2xl" style="background:var(--card-bg);border:1px solid var(--card-border);">
          <h3 class="text-xl font-bold mb-4" style="color:var(--text-heading);">
            <span class="mr-2 opacity-50 font-mono text-base">{stage.sectionNumber}</span>
            {stage.title}
          </h3>
          <p class="text-lg leading-relaxed" style="color:var(--text-body);">
            {stage.content}
          </p>
        </div>
      ))}
    </div>
  )}
</div>
