---
interface Props {
  content: any;
}
const { content } = Astro.props;
---
<div class="relative py-20 overflow-hidden">
  <div class="absolute inset-0" style="background:linear-gradient(135deg, rgba(255,255,255,0.03) 0%, transparent 50%);"></div>
  <div class="relative z-10">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);">
      <span class="text-sm font-medium" style="color:var(--text-heading);">परिच्छेद {content.sectionNumber}</span>
    </div>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4" style="color:var(--text-heading);">
      {content.title}
    </h1>
    <p class="text-lg max-w-2xl" style="color:var(--text-body);">{content.content}</p>
  </div>
</div>
