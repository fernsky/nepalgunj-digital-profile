---
interface Props {
  content: any;
}
const { content } = Astro.props;
---
<div class="prose prose-invert max-w-none">
  <h2 class="text-3xl font-extrabold mb-6" style="color:var(--text-heading);">{content.sectionNumber} {content.title}</h2>
  
  <div class="space-y-6 text-lg leading-relaxed" style="color:var(--text-body);">
    {content.paragraphs?.map((p: string) => (
      <p>{p}</p>
    ))}
  </div>
</div>
