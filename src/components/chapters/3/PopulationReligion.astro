---
import InteractiveChart from "../../InteractiveChart.astro";
interface Props {
    content: {
        caption?: string;
        barChartData?: any[];
    };
    lang?: any;
}

const { content, lang = "ne" } = Astro.props;
const barChartData = content?.barChartData ?? [];
const caption = content?.caption ?? "Population by Religion";
---

<InteractiveChart 
  type="bar"
  data={barChartData}
  config={{
    xKey: "religion",
    labels: Object.keys(barChartData[0] || {}).filter(k => k !== 'religion'),
    title: caption,
    colors: ["#3b82f6", "#f43f5e"]
  }}
  id="population-religion"
  lang={lang}
/>
