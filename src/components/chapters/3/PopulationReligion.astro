---
import InteractiveChart from "../../InteractiveChart.astro";
interface Props {
    content: {
        caption?: string;
        barChartData?: any[];
    };
}

const { content } = Astro.props;
const barChartData = content?.barChartData ?? [];
const caption = content?.caption ?? "Population by Religion";
---

<InteractiveChart 
  type="bar"
  data={barChartData}
  config={{
    xKey: "religion",
    labels: ["population"],
    title: caption,
    colors: ["#f59e0b"]
  }}
/>
