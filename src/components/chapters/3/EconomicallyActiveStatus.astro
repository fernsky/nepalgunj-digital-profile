---
import InteractiveChart from "../../InteractiveChart.astro";
interface Props {
    content: {
        caption?: string;
        barChartData?: any[];
    };
    lang?: any;
}

const { content, lang = "ne" } = Astro.props;
const barChartData = content?.barChartData ?? [];
const caption = content?.caption ?? "Economically Active Population Status";
---

<InteractiveChart 
  type="bar"
  data={barChartData}
  config={{
    xKey: "category",
    labels: Object.keys(barChartData[0] || {}).filter(k => k !== 'category'),
    title: caption,
    colors: ["#3b82f6", "#f97316"]
  }}
  id="economically-active-status"
  lang={lang}
/>
