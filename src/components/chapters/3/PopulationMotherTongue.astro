---
interface Props {
    content: {
        caption?: string;
        barChartData?: any[];
    };
}

const { content } = Astro.props;
const barChartData = content?.barChartData ?? [];
const caption = content?.caption ?? "Population by Mother Tongue";
---

<div class="w-full">
    <!-- Bar Chart -->
    <div
        class="my-10 p-6 rounded-xl overflow-hidden"
        style="background:var(--card-bg); border:1px solid var(--card-border);"
    >
        <h3
            class="text-xl font-bold mb-6 text-center"
            style="color:var(--text-heading);"
        >
            {caption}
        </h3>
        <div
            id="language-bar-chart"
            class="w-full h-[400px] flex justify-center items-center"
            data-chart={JSON.stringify(barChartData)}
        >
        </div>
    </div>
</div>

<script>
    import * as d3 from "d3";

    function renderChart() {
        const container = document.getElementById("language-bar-chart");
        if (!container) return;

        container.innerHTML = "";
        const dataString = container.getAttribute("data-chart");
        if (!dataString) return;

        const data = JSON.parse(dataString);
        const width = container.clientWidth || 800;
        const height = 400;
        const margin = { top: 20, right: 30, bottom: 60, left: 70 };

        d3.selectAll(".lang-tooltip").remove();
        const tooltip = d3
            .select("body")
            .append("div")
            .attr(
                "class",
                "lang-tooltip absolute hidden bg-gray-900 border border-gray-700 text-white p-3 rounded-lg shadow-xl shadow-black/50 z-50 text-sm pointer-events-none transform -translate-x-1/2 -translate-y-full mt-[-10px]"
            )
            .style("opacity", 0);

        const xScale = d3
            .scaleBand()
            .domain(data.map((d: any) => d.language))
            .range([margin.left, width - margin.right])
            .padding(0.3);

        const yScale = d3
            .scaleLinear()
            .domain([
                0,
                (d3.max(data, (d: any) => d.population) as any) || 1000,
            ])
            .nice()
            .range([height - margin.bottom, margin.top]);

        const svg = d3
            .select(container)
            .append("svg")
            .attr("width", width)
            .attr("height", height)
            .attr("viewBox", `0 0 ${width} ${height}`)
            .attr("style", "max-width: 100%; height: auto;");

        const color = "#3b82f6";
        const isLight = document.documentElement.classList.contains("light");
        const tickColor = isLight ? "#555555" : "#a1a1aa";

        // Add Y axis
        svg.append("g")
            .attr("transform", `translate(${margin.left},0)`)
            .call(
                d3
                    .axisLeft(yScale)
                    .ticks(5)
                    .tickFormat((d: any) => (d >= 1000 ? d / 1000 + "k" : d))
            )
            .call((g) => g.select(".domain").remove())
            .call((g) =>
                g
                    .selectAll(".tick line")
                    .attr("stroke", tickColor)
                    .attr("opacity", 0.3)
            )
            .call((g) =>
                g
                    .selectAll(".tick text")
                    .attr("fill", tickColor)
                    .attr("font-size", "12px")
            );

        // Add grid lines
        svg.append("g")
            .selectAll("line")
            .data(yScale.ticks(5))
            .join("line")
            .attr("x1", margin.left)
            .attr("x2", width - margin.right)
            .attr("y1", (d) => yScale(d))
            .attr("y2", (d) => yScale(d))
            .attr("stroke", tickColor)
            .attr("stroke-dasharray", "2,2")
            .attr("opacity", 0.15);

        // Add X axis
        svg.append("g")
            .attr("transform", `translate(0,${height - margin.bottom})`)
            .call(d3.axisBottom(xScale))
            .call((g) => g.select(".domain").remove())
            .call((g) =>
                g
                    .selectAll(".tick text")
                    .attr("fill", tickColor)
                    .attr("font-size", "12px")
                    .attr("transform", "rotate(-35)")
                    .attr("text-anchor", "end")
                    .attr("dx", "-0.5em")
                    .attr("dy", "0.5em")
            );

        // Draw bars
        svg.append("g")
            .selectAll("rect")
            .data(data)
            .join("rect")
            .attr("x", (d: any) => xScale(d.language) || 0)
            .attr("width", xScale.bandwidth())
            .attr("y", height - margin.bottom)
            .attr("height", 0)
            .attr("fill", color)
            .attr("rx", 4)
            .on("mouseover", function (event, d: any) {
                d3.select(this).attr("opacity", 0.8).attr("fill", "#60a5fa");
                tooltip.html(
                    `<div class="font-bold text-gray-300 mb-1">${
                        d.language
                    }</div><div class="flex justify-between gap-4"><span class="text-blue-300">Population:</span><span class="font-medium">${d.population.toLocaleString()}</span></div>`
                );
                tooltip.style("display", "block").style("opacity", 1);
            })
            .on("mousemove", function (event) {
                tooltip
                    .style("left", event.pageX + "px")
                    .style("top", event.pageY - 10 + "px");
            })
            .on("mouseout", function () {
                d3.select(this).attr("opacity", 1).attr("fill", color);
                tooltip.style("display", "none").style("opacity", 0);
            })
            .transition()
            .duration(800)
            .delay((d, i) => i * 50)
            .attr("y", (d: any) => yScale(d.population))
            .attr(
                "height",
                (d: any) => height - margin.bottom - yScale(d.population)
            );
    }

    let observerInitialized = false;
    function init() {
        renderChart();
        if (!observerInitialized) {
            window.addEventListener("resize", renderChart);
            const observer = new MutationObserver(() => renderChart());
            observer.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ["class"],
            });
            observerInitialized = true;
        }
    }

    document.addEventListener("astro:page-load", init);
    if (document.readyState === "complete") init();
    else document.addEventListener("DOMContentLoaded", init);
</script>
