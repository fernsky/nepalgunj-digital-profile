---
import InteractiveChart from "../../InteractiveChart.astro";
interface Props {
    content: {
        caption?: string;
        barChartData?: any[];
    };
    lang?: any;
}

const { content, lang = "ne" } = Astro.props;
const barChartData = content?.barChartData ?? [];
const caption = content?.caption ?? "Population by Mother Tongue";
---

<InteractiveChart 
  type="bar"
  data={barChartData}
  config={{
    xKey: "language",
    labels: ["population"],
    title: caption,
    colors: ["#3b82f6"]
  }}
  id="population-mother-tongue"
  lang={lang}
/>
