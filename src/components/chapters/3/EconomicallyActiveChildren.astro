---
import InteractiveChart from "../../InteractiveChart.astro";
interface Props {
    content: {
        caption?: string;
        barChartData?: any[];
    };
}

const { content } = Astro.props;
const barChartData = content?.barChartData ?? [];
const caption = content?.caption ?? "Economically Active Children Status";
---

<InteractiveChart 
  type="bar"
  data={barChartData}
  config={{
    xKey: "category",
    labels: Object.keys(barChartData[0] || {}).filter(k => k !== 'category'),
    title: caption,
    colors: ["#f59e0b", "#0ea5e9", "#84cc16", "#ef4444"]
  }}
  id="economically-active-children"
/>
