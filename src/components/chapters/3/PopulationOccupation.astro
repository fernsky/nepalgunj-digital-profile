---
import InteractiveChart from "../../InteractiveChart.astro";
interface Props {
    content: {
        caption?: string;
        barChartData?: any[];
    };
    lang?: any;
}

const { content, lang = "ne" } = Astro.props;
const barChartData = content?.barChartData ?? [];
const caption = content?.caption ?? "Population by Occupation";
---

<InteractiveChart 
  type="bar"
  data={barChartData}
  config={{
    xKey: "category",
    labels: ["population"],
    title: caption,
    colors: ["#6366f1"]
  }}
  id="population-occupation"
  lang={lang}
/>
