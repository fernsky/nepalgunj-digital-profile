---
import InteractiveChart from "../../InteractiveChart.astro";
interface Props {
    content: {
        caption?: string;
        pieChartData?: any[];
    };
}

const { content } = Astro.props;
// Use population for the actual pie slices, 'value' is just the percentage
const pieChartData = (content?.pieChartData ?? []).map(d => ({
    ...d,
    value: d.population || d.value
}));
const caption = content?.caption ?? "Economically Active Population";
---

<InteractiveChart 
  type="pie"
  data={pieChartData}
  config={{
    xKey: "category",
    labels: ["value"],
    title: caption
  }}
/>
