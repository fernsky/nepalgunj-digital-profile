---
import { type Lang } from "../../../i18n/translations";

interface Props {
    content: {
        caption?: string;
        barChartData?: any[];
    };
    lang?: Lang;
}

const { content, lang = "ne" } = Astro.props;
const barChartData = content?.barChartData ?? [];
const caption = content?.caption ?? (lang === "ne" ? "बसाइँसराई जनसंख्या विवरण" : "Migration Population Detail");
---

<div class="w-full">
    <div
        class="my-10 p-6 rounded-xl overflow-hidden"
        style="background:var(--card-bg); border:1px solid var(--card-border);"
    >
        <h3
            class="text-xl font-bold mb-6 text-center text-balance max-w-2xl mx-auto"
            style="color:var(--text-heading);"
        >
            {caption}
        </h3>
        <div
            id="migration-bar-chart"
            class="w-full h-[400px] flex justify-center items-center"
            data-chart={JSON.stringify(barChartData)}
            data-lang={lang}
        >
        </div>
    </div>
</div>

<script>
    import * as d3 from "d3";

    function toNepaliDigits(num: any): string {
        if (num === null || num === undefined) return String(num);
        const str = num.toString();
        const nepaliDigits = ["०", "१", "२", "३", "४", "५", "६", "७", "८", "९"];
        return str.replace(/\d/g, (digit: string) => nepaliDigits[parseInt(digit)]);
    }

    function translateLabel(label: string, lang: string): string {
        if (lang === "en" || !label) return String(label);
        const translations: Record<string, string> = {
            "Male": "पुरुष",
            "Female": "महिला",
            "Total": "जम्मा",
            "Population": "जनसंख्या",
            "population": "जनसंख्या"
        };
        const wardMatch = String(label).match(/^W(\d+)$/);
        if (wardMatch) {
            return "वडा " + toNepaliDigits(wardMatch[1]);
        }
        return translations[String(label)] || String(label);
    }

    function formatNumber(num: number, lang: string): string {
        if (lang === "ne") {
            return toNepaliDigits(num.toLocaleString());
        }
        return num.toLocaleString();
    }

    function renderChart() {
        const container = document.getElementById("migration-bar-chart");
        if (!container) return;

        // Read lang from data attribute
        const lang = container.getAttribute("data-lang") || document.documentElement.lang || "ne";

        container.innerHTML = "";
        const dataString = container.getAttribute("data-chart");
        if (!dataString) return;

        const data = JSON.parse(dataString);
        if (data.length === 0) return;

        const isMobile = window.innerWidth < 640;
        const width = container.clientWidth || 800;
        const height = isMobile ? 350 : 400;
        const margin = { 
            top: 40, 
            right: isMobile ? 15 : 30, 
            bottom: isMobile ? 100 : 80, 
            left: isMobile ? 70 : 80 
        };

        const subgroups = Object.keys(data[0]).filter(k => k !== 'category');
        const groups = data.map((d: any) => d.category);

        const svg = d3.select(container)
            .append("svg")
            .attr("width", width)
            .attr("height", height)
            .append("g")
            .attr("transform", `translate(${margin.left},${margin.top})`);

        const x = d3.scaleBand()
            .domain(groups)
            .range([0, width - margin.left - margin.right])
            .padding(0.2);

        svg.append("g")
            .attr("transform", `translate(0,${height - margin.top - margin.bottom})`)
            .call(d3.axisBottom(x).tickSize(0).tickFormat((d) => translateLabel(String(d), lang)))
            .selectAll("text")
            .style("text-anchor", "middle")
            .style("font-size", "12px")
            .style("fill", "var(--text-body)")
            .attr("dy", "1em")
            .call(wrap as any, x.bandwidth());

        const maxY = d3.max(data, (d: any) => d3.max(subgroups, (key: string) => Number(d[key]))) || 0;
        const y = d3.scaleLinear()
            .domain([0, maxY * 1.1])
            .range([height - margin.top - margin.bottom, 0]);

        // Y-axis
        svg.append("g")
            .call(d3.axisLeft(y).ticks(5).tickFormat((d: any) => lang === "ne" ? toNepaliDigits(d) : d3.format(".2s")(d)))
            .selectAll("text")
            .style("font-size", "12px")
            .style("fill", "var(--text-body)");
            
        // Grid lines
        svg.append("g")
            .attr("class", "grid")
            .call(d3.axisLeft(y).ticks(5).tickSize(-(width - margin.left - margin.right)).tickFormat(() => ""))
            .selectAll('line').style("stroke", "rgba(100, 100, 100, 0.1)");
        svg.selectAll('.domain').remove();

        const xSubgroup = d3.scaleBand()
            .domain(subgroups)
            .range([0, x.bandwidth()])
            .padding(0.05);

        const color = d3.scaleOrdinal()
            .domain(subgroups)
            .range(["#0284c7", "#e879f9"]);

        // Tooltip
        d3.selectAll(".migration-tooltip").remove();
        const tooltip = d3.select("body")
            .append("div")
            .attr("class", "migration-tooltip absolute hidden bg-gray-900 border border-gray-700 text-white p-3 rounded-lg shadow-xl shadow-black/50 z-50 text-sm pointer-events-none transform -translate-x-1/2 -translate-y-full mt-[-10px]")
            .style("opacity", 0);

        svg.append("g")
            .selectAll("g")
            .data(data)
            .join("g")
            .attr("transform", (d: any) => `translate(${x(d.category)},0)`)
            .selectAll("rect")
            .data((d: any) => subgroups.map(key => ({key, value: d[key], category: d.category})))
            .join("rect")
            .attr("x", (d: any) => xSubgroup(d.key) || 0)
            .attr("y", (d: any) => y(d.value))
            .attr("width", xSubgroup.bandwidth())
            .attr("height", (d: any) => (height - margin.top - margin.bottom) - y(d.value))
            .attr("fill", (d: any) => color(d.key) as string)
            .on("mouseover", function(event: any, d: any) {
                d3.select(this).attr("opacity", 0.8);
                tooltip.html(`
                    <div class="font-bold text-gray-300 mb-1">${translateLabel(d.category, lang)}</div>
                    <div class="flex justify-between gap-4">
                        <span style="color:${color(d.key)}">${translateLabel(d.key, lang)}:</span>
                        <span class="font-medium">${formatNumber(d.value, lang)}</span>
                    </div>
                `);
                tooltip.style("display", "block").style("opacity", 1);
            })
            .on("mousemove", function(event: any) {
                tooltip.style("left", event.pageX + "px").style("top", event.pageY - 10 + "px");
            })
            .on("mouseout", function() {
                d3.select(this).attr("opacity", 1);
                tooltip.style("display", "none").style("opacity", 0);
            });

        // Legend
        const legend = svg.append("g")
            .attr("transform", `translate(${(width - margin.left - margin.right) / 2}, ${height - margin.top - 10})`)
            .attr("text-anchor", "middle");

        let legendWidth = 0;
        const legendItems = legend.selectAll("g")
            .data(subgroups)
            .join("g")
            .attr("transform", function() {
                const transform = `translate(${legendWidth}, 0)`;
                legendWidth += 120;
                return transform;
            });
            
        legendItems.append("rect")
            .attr("width", 12).attr("height", 12).attr("x", -15).attr("y", -10)
            .attr("fill", (d: any) => color(d) as string);
            
        legendItems.append("text")
            .text((d: any) => translateLabel(d, lang))
            .attr("x", 5).attr("y", 0)
            .style("font-size", "12px").style("fill", "var(--text-body)").attr("text-anchor", "start");
            
        legend.attr("transform", `translate(${((width - margin.left - margin.right) - legendWidth + 80) / 2}, ${height - margin.top + 20})`);
    }

    function wrap(text: any, width: number) {
        text.each(function(this: any) {
            var textEl = d3.select(this),
                words = textEl.text().split(/[ \/]+/).reverse(),
                word: string | undefined,
                line: string[] = [],
                lineNumber = 0,
                lineHeight = 1.1,
                y = textEl.attr("y"),
                dy = parseFloat(textEl.attr("dy")),
                tspan = textEl.text(null).append("tspan").attr("x", 0).attr("y", y).attr("dy", dy + "em");
            while (word = words.pop()) {
                line.push(word);
                tspan.text(line.join(" "));
                if ((tspan.node()?.getComputedTextLength() || 0) > width) {
                    line.pop();
                    tspan.text(line.join(" "));
                    line = [word];
                    tspan = textEl.append("tspan").attr("x", 0).attr("y", y).attr("dy", ++lineNumber * lineHeight + dy + "em").text(word);
                }
            }
        });
    }

    let observerInitialized = false;
    function init() {
        renderChart();
        if (!observerInitialized) {
            window.addEventListener("resize", renderChart);
            const observer = new MutationObserver(() => renderChart());
            observer.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ["class"],
            });
            observerInitialized = true;
        }
    }

    document.addEventListener("astro:page-load", init);
    if (document.readyState === "complete") init();
    else document.addEventListener("DOMContentLoaded", init);
</script>
