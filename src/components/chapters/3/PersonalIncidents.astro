---
interface Props {
    content: {
        sectionNumber: string;
        title: string;
        description?: string;
        table?: {
            caption?: string;
            headers?: string[];
            rows?: string[][];
            summaryRow?: string[];
        };
    };
}

const { content } = Astro.props;
const table = content?.table ?? {};
const headers = table.headers ?? [];
const rows = table.rows ?? [];
const summaryRow = table.summaryRow ?? [];
---

<div class="w-full">
    <h2
        class="font-serif text-3xl md:text-4xl font-medium mb-6"
        style="color:var(--text-heading);"
    >
        {content.sectionNumber}
        {content.title}
    </h2>
    <div
        class="font-serif text-lg md:text-xl font-light leading-relaxed mb-8"
        style="color:var(--text-body);"
    >
        {content.description ?? ""}
    </div>

    <div
        class="overflow-x-auto rounded-xl border mb-8"
        style="background:var(--card-bg); border-color:var(--border);"
    >
        <table class="w-full text-left border-collapse">
            <caption
                class="p-4 text-lg font-semibold text-left border-b"
                style="color:var(--text-heading); border-color:var(--card-border);"
            >
                {table.caption ?? ""}
            </caption>
            <thead>
                <tr style="background:var(--hover-bg);">
                    {
                        headers.map((header) => (
                            <th
                                class="p-4 font-semibold text-sm whitespace-nowrap"
                                style="color:var(--text-heading); border-bottom:1px solid var(--card-border);"
                            >
                                {header}
                            </th>
                        ))
                    }
                </tr>
            </thead>
            <tbody>
                {
                    rows.map((row) => (
                        <tr
                            class="transition-colors hover:bg-black/20"
                            style="border-bottom:1px solid var(--card-border);"
                        >
                            {row.map((cell, index) => (
                                <td
                                    class={`p-4 text-sm ${
                                        index === 0 ? "font-medium" : ""
                                    }`}
                                    style="color:var(--text-body);"
                                >
                                    {cell}
                                </td>
                            ))}
                        </tr>
                    ))
                }
                <tr
                    class="transition-colors hover:bg-black/20 font-bold"
                    style="border-bottom:1px solid var(--card-border);"
                >
                    {
                        summaryRow.map((cell) => (
                            <td
                                class="p-4 text-sm whitespace-nowrap"
                                style="color:var(--text-heading);"
                            >
                                {cell}
                            </td>
                        ))
                    }
                </tr>
            </tbody>
        </table>
    </div>
</div>
