---
import InteractiveChart from "../../InteractiveChart.astro";
interface Props {
    content: {
        caption?: string;
        barChartData?: any[];
        colors?: string[];
        id?: string;
    };
}

const { content } = Astro.props;
const barChartData = content?.barChartData ?? [];
const caption = content?.caption ?? "";
const colors = content?.colors ?? ["#0ea5e9", "#f43f5e", "#10b981", "#f59e0b", "#8b5cf6"];
const chartId = content?.id ?? "grouped-bar-chart-" + Math.random().toString(36).substring(7);
---

<InteractiveChart 
  type="bar"
  data={barChartData}
  config={{
    xKey: "category",
    labels: Object.keys(barChartData[0] || {}).filter(k => k !== 'category'),
    colors: colors,
    title: caption
  }}
  id={chartId}
/>
